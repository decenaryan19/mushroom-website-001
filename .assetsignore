# Never upload dev / VCS / build tooling
.git
**/.git
**/.git/**
node_modules
**/node_modules/**
.github
**/.github/**
scripts
scripts/**
.vscode
.vscode/**
dist
dist/**

# Unoptimized originals (site serves WebP only)
images/raw
images/raw/**
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.pdf

# Dev / config (not needed on the live site)
*.md
package.json
package-lock.json
wrangler.toml
.gitignore
.gitattributes
.assetsignore
lighthouse*.json

# Unused font (removed from CSS)
fonts/*.ttf
